
pipeline {
    agent any
    tools {
        maven 'maven_3.9.16'
    }
    stages {
        stage('Clone code') {
            steps {
                echo 'cloned suceesfully'
                git branch:'main', url: 'https://github.com/gollarakesh266-web/REALTIMEPROJECT.git'
            }
        }
        stage('Build and compile the code') {
            steps {
                echo 'Built successfully'
                sh 'cd Application && mvn clean package'
            }
        }
        stage('Code Analysis using SonarQube') {
            steps {
                echo 'Scanned sucessfully'
                sh ''' cd Application && mvn sonar:sonar \
                       -Dsonar.host.url=http://54.145.235.151:9000 \
                       -Dsonar.login=squ_75c500c33665d9604bd99909e6c2f3ab28ce5aeb '''
            }
        }
        stage('Build Docker image') {
            steps {
                script {
                echo 'Scanned sucessfully'
                sh 'cd Application && docker build -t gollarakesh/dockrepo1:${BUILD_NUMBER} -f Dockerfile .'
                }
            }
        }
        stage('Scan image') {
            steps {
                echo 'scanned successfully'
                sh 'trivy image gollarakesh/dockrepo1:${BUILD_NUMBER}'
            }
        }
        stage('Push image to docker hub') {
            steps {
                script { 
                echo 'pushed image'
                    withCredentials([string(credentialsId: 'dockerhub', variable: 'dockerhub')]) {
                    sh 'docker login -u gollarakesh -p ${dockerhub}'
                }
                sh 'docker push gollarakesh/dockrepo1:${BUILD_NUMBER}'
                }
            }
        }
        stage('Update the deployment yaml file') {
           environment {
            GITHUB_REPO = "REALTIMEPROJECT"
            GITHUB_USER = "gollarakesh266-web"
           }
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'github')]) {
                  sh '''git config user.email "gollarakesh266@gmail.com"
                        git config user.name "gollarakesh266-web"
                        sed -i "s/dockrepo1:.*/dockrepo1:${BUILD_NUMBER}/g" Ansible/k8s_deployment.yaml
                        git add . 
                        git commit -m "updated deploment successfully"
                        git push https://${github}@github.com/${GITHUB_USER}/${GITHUB_REPO} HEAD:main '''
                    }
                
            }
        }
    }
}
